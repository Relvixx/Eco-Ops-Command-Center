# Eco-Ops Command Center — Environment Variables
# Copy this to .env.local for local development.
# NEVER commit .env.local to git.
# Set these in Vercel Dashboard → Project Settings → Environment Variables for production.
# DO NOT use VITE_ prefix — these keys must stay server-side only.

# Primary AI provider (Google Gemini 1.5 Flash)
GEMINI_API_KEY=your_gemini_api_key_here

# Secondary AI provider (Groq llama3-8b-8192)
GROQ_API_KEY=your_groq_api_key_here
